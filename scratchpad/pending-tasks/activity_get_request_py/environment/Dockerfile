FROM ubuntu:24.04

RUN apt-get update -y && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        curl ca-certificates git python3 python3-pip python3-pytest bash && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN pip3 install --break-system-packages temporalio aiohttp pytest-asyncio

RUN mkdir -p /home/user && chmod 0755 /home/user

LABEL Author="any-task-builder"
LABEL Description="Temporal.io Python environment with aiohttp for activity task."

RUN mkdir -p /home/user/app

# Container contents:
#   - temporalio and aiohttp installed.
#   - /home/user/app  — empty project directory for the task

CMD ["/bin/bash", "-c", "trap : TERM INT; sleep infinity & wait"]
